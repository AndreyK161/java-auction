<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="create_table_owner" author="a.kopeykin">
        <createTable tableName="owners">
            <column name="guid" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(1000)">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="varchar(1000)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="create_table_photos" author="a.kopeykin">
        <createTable tableName="photos">
            <column name="guid" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="mime_type" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="varchar(1000)"/>
            <column name="entity_type" type="varchar(255)"/>
            <column name="entity_guid" type="uuid"/>
        </createTable>
    </changeSet>

    <changeSet id="create_table_lots" author="a.kopeykin">
        <createTable tableName="lots">
            <column name="guid" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(1000)"/>
            <column name="start_price" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="price_step" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column defaultValueBoolean="false" name="deleted" type="boolean"/>
            <column name="owner_guid" type="uuid">
                <constraints referencedTableName="owners" referencedColumnNames="guid"
                             foreignKeyName="fk_lot_owner"/>
            </column>
        </createTable>
    </changeSet>

    <!--TODO остальные таблицы и их связи-->
</databaseChangeLog>
